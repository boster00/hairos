# -----------------------------------------------------------------------------
# Resend: https://shipfa.st/docs/features/emails
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Database URI: https://shipfa.st/docs/features/database
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HairOS: optional in-app demo seed (use without CJGEO_DEV_FAKE_AUTH for real auth + demo data)
# HAIR_OS_UI_DEMO=1

# -----------------------------------------------------------------------------
# Local UI / agent testing only — bypasses private-route auth and shows dev sidebar items.
# Never set CJGEO_DEV_FAKE_AUTH=1 in production or staging.
# -----------------------------------------------------------------------------
# CJGEO_DEV_FAKE_AUTH=1

# -----------------------------------------------------------------------------
# Stripe: https://shipfa.st/docs/features/payments
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Metering: testing quota override (all users get this monthly credit quota)
# Set METERING_TEST_QUOTA=10000 for testing; 100 or unset for beta/production
# -----------------------------------------------------------------------------
METERING_TEST_QUOTA=10000

# Quota is OFF by default (no "Monthly quota exceeded"). To enforce quota, set:
# ENABLE_METERING=true
# To explicitly bypass when needed: DISABLE_METERING=true

# -----------------------------------------------------------------------------
# Cron & Master of Coins (monthly credit resets)
# Vercel cron calls /api/cron/trigger which invokes the MoC worker. Set at least one secret.
# -----------------------------------------------------------------------------
# CRON_SECRET=  # required for POST /api/content-pipeline/tick (x-cron-secret header)
# MASTER_OF_COINS_SECRET=

# -----------------------------------------------------------------------------
# Site URL (used by cron/MoC worker to call back the app; e.g. https://yourapp.vercel.app)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=
# SITE_URL=

# Local UI testing: bypass private-route auth (never enable in production)
# CJGEO_DEV_FAKE_AUTH=1
# NEXT_PUBLIC_CJGEO_DEV_FAKE_AUTH=1  # client-side empty Content Magic list when no session (dev only)
# HairOS Phase 2 UI demo (in-memory salon/clients/social/newsletter; no DB tables required)
# HAIR_OS_UI_DEMO=1

# Return mock HTML from POST /api/content-magic/template-from-url (dev only)
# CONTENT_MAGIC_TEMPLATE_MOCK=1

# Topic Research: force mock DataForSEO responses without API keys
# TOPIC_RESEARCH_MOCK=1

# -----------------------------------------------------------------------------
# Admin: unlimited quota for this email when ADMIN_UNLIMITED_QUOTA=true
# Admin routes (e.g. /api/admin/credits/adjust, /api/admin/users) require email in allowlist.
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com
# ADMIN_EMAILS=admin@example.com,other@example.com
# ADMIN_UNLIMITED_QUOTA=true

# -----------------------------------------------------------------------------
# HairOS: Twilio (SMS reminders + phone numbers)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=   # platform-level fallback number

# -----------------------------------------------------------------------------
# HairOS: Vapi.ai (AI phone answering)
# -----------------------------------------------------------------------------
VAPI_API_KEY=

# -----------------------------------------------------------------------------
# HairOS: Cron secret for /api/reminders
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# HairOS: Resend sender
# -----------------------------------------------------------------------------
RESEND_FROM_EMAIL=noreply@hairos.app

# -----------------------------------------------------------------------------
# HairOS Phase 2 — demo + integrations
# -----------------------------------------------------------------------------
# HAIR_OS_UI_DEMO=1
# HAIR_OS_GOOGLE_REFRESH_TOKEN=   # optional: skip OAuth in demo; enables Calendar API after booking
# HAIR_OS_GOOGLE_CALENDAR_SCREENSHOT_URL=  # optional: public Google Calendar event htmlLink for quest screenshot
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# HAIR_OS_SOCIAL_IDEAS_MODEL=   # optional override for POST /api/hair/social-ideas (defaults AI_MODEL_STANDARD)

# GuildOS quest evidence upload (scripts/quest-submit-evidence.mjs) — never commit real keys
# GUILDOS_QUEST_SUPABASE_URL=
# GUILDOS_QUEST_SUPABASE_SERVICE_KEY=